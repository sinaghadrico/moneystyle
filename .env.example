# Database
DATABASE_URL="postgresql://revenue:yourpassword@localhost:5434/revenue"
DIRECT_URL="postgresql://revenue:yourpassword@localhost:5434/revenue"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_WEBHOOK_SECRET="your-webhook-secret"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="your_bot_username"

# OpenAI (optional — used for AI features)
OPENAI_API_KEY="sk-proj-..."

# MinIO (local file storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=transaction-media
MINIO_USE_SSL=false

# AWS S3 (production file storage — optional)
AWS_S3_BUCKET="your-bucket"
AWS_REGION="eu-north-1"
AWS_ACCESS_KEY_ID="your-key"
AWS_SECRET_ACCESS_KEY="your-secret"

# Auth (NextAuth.js v5)
AUTH_SECRET="generate-with: openssl rand -hex 32"
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3020

# Google OAuth (optional)
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-secret"

# GitHub OAuth (optional)
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-secret"

# Admin user (created on first run)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="your-secure-password"

# Google Maps (optional — for Money Map feature)
NEXT_PUBLIC_GOOGLE_MAPS_KEY="your-maps-key"

# Remote deploy (optional)
REMOTE_HOST="your-server-ip"
REMOTE_USER="ec2-user"
REMOTE_KEY="~/.ssh/your-key.pem"
REMOTE_DB_PASSWORD="your-db-password"
