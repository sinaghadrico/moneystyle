generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id            String                 @id @default(cuid())
  name          String                 @unique
  color         String                 @default("#6b7280")
  icon          String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  transactions  Transaction[]
  budget        Budget?
  merchantRules MerchantCategoryRule[]
  splits        TransactionSplit[]     @relation("SplitCategories")

  @@map("categories")
}

model Budget {
  id             String   @id @default(cuid())
  categoryId     String   @unique
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  monthlyLimit   Decimal  @db.Decimal(12, 2)
  alertThreshold Int      @default(80)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("budgets")
}

model Tag {
  id           String           @id @default(cuid())
  name         String           @unique
  color        String           @default("#6b7280")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  transactions TransactionTag[]

  @@map("tags")
}

model TransactionTag {
  transactionId String
  tagId         String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@map("transaction_tags")
}

model Account {
  id           String        @id @default(cuid())
  name         String        @unique
  bank         String?
  color        String        @default("#3b82f6")
  icon         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]

  @@map("accounts")
}

model Transaction {
  id           String               @id @default(cuid())
  date         DateTime
  time         String?
  amount       Decimal?             @db.Decimal(12, 2)
  currency     String               @default("AED")
  type         String
  categoryId   String?
  category     Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  accountId    String
  account      Account              @relation(fields: [accountId], references: [id])
  merchant     String?
  description  String?
  items        String?
  source       String?
  hasReceipt   Boolean              @default(false)
  mediaFiles   String[]
  mergedIntoId String?
  mergedInto   Transaction?         @relation("MergedTransactions", fields: [mergedIntoId], references: [id])
  mergedFrom   Transaction[]        @relation("MergedTransactions")
  tags         TransactionTag[]
  splits       TransactionSplit[]   @relation("TransactionSplits")
  lineItems    TransactionItem[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([date])
  @@index([categoryId])
  @@index([accountId])
  @@index([type])
  @@index([merchant])
  @@index([mergedIntoId])
  @@map("transactions")
}

model MerchantCategoryRule {
  id         String   @id @default(cuid())
  pattern    String   @unique
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@map("merchant_category_rules")
}

model SavingsGoal {
  id            String    @id @default(cuid())
  name          String
  targetAmount  Decimal   @db.Decimal(12, 2)
  currentAmount Decimal   @db.Decimal(12, 2) @default(0)
  deadline      DateTime?
  color         String    @default("#10b981")
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("savings_goals")
}

model Person {
  id          String             @id @default(cuid())
  name        String             @unique
  phone       String?
  color       String             @default("#6b7280")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  splits      TransactionSplit[]
  settlements Settlement[]

  @@map("persons")
}

model Settlement {
  id        String   @id @default(cuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime @default(now())
  note      String?
  source    String?
  createdAt DateTime @default(now())

  @@map("settlements")
}

model TransactionSplit {
  id            String       @id @default(cuid())
  transactionId String
  transaction   Transaction  @relation("TransactionSplits", fields: [transactionId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?    @relation("SplitCategories", fields: [categoryId], references: [id], onDelete: SetNull)
  personId      String?
  person        Person?      @relation(fields: [personId], references: [id], onDelete: SetNull)
  amount        Decimal      @db.Decimal(12, 2)
  description   String?
  createdAt     DateTime     @default(now())

  @@index([transactionId])
  @@index([personId])
  @@map("transaction_splits")
}

model TransactionItem {
  id             String      @id @default(cuid())
  transactionId  String
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  name           String
  normalizedName String      @default("")
  quantity       Float       @default(1)
  unitPrice      Float?
  totalPrice     Float
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())

  @@index([transactionId])
  @@index([normalizedName])
  @@map("transaction_items")
}

model ItemGroup {
  id            String   @id @default(cuid())
  canonicalName String   @unique
  rawNames      String[]
  source        String   @default("manual")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("item_groups")
}

model ShoppingList {
  id        String             @id @default(cuid())
  name      String
  items     ShoppingListItem[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@map("shopping_lists")
}

model ShoppingListItem {
  id             String       @id @default(cuid())
  listId         String
  list           ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  itemName       String
  normalizedName String       @default("")
  quantity       Float        @default(1)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([listId])
  @@index([normalizedName])
  @@map("shopping_list_items")
}

model SmsPattern {
  id                   String   @id @default(cuid())
  name                 String   @unique
  regex                String
  type                 String   // "income" | "expense" | "auto"
  priority             Int      @default(50)
  amountCaptureGroup   Int      @default(1)
  merchantCaptureGroup Int?
  enabled              Boolean  @default(true)
  creditKeywords       String?  // comma-separated, for type="auto"
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([priority])
  @@map("sms_patterns")
}

model IncomeSource {
  id         String   @id @default(cuid())
  name       String
  amount     Decimal  @db.Decimal(12, 2)
  depositDay Int      @default(1)
  currency   String   @default("AED")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("income_sources")
}

model Reserve {
  id        String             @id @default(cuid())
  name      String
  amount    Decimal            @db.Decimal(12, 2)
  currency  String             @default("AED")
  type      String
  location  String
  note      String?
  snapshots ReserveSnapshot[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@map("reserves")
}

model ReserveSnapshot {
  id         String   @id @default(cuid())
  reserveId  String
  reserve    Reserve  @relation(fields: [reserveId], references: [id], onDelete: Cascade)
  amount     Decimal  @db.Decimal(12, 2)
  note       String?
  recordedAt DateTime @default(now())

  @@index([reserveId])
  @@map("reserve_snapshots")
}

model Installment {
  id           String               @id @default(cuid())
  name         String
  amount       Decimal              @db.Decimal(12, 2)
  currency     String               @default("AED")
  dueDay       Int                  @default(1)
  totalCount   Int?
  paidCount    Int                  @default(0)
  isActive     Boolean              @default(true)
  reminderDays Int                  @default(2)
  payments     InstallmentPayment[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@map("installments")
}

model InstallmentPayment {
  id            String      @id @default(cuid())
  installmentId String
  installment   Installment @relation(fields: [installmentId], references: [id], onDelete: Cascade)
  amount        Decimal     @db.Decimal(12, 2)
  note          String?
  paidAt        DateTime    @default(now())

  @@index([installmentId])
  @@map("installment_payments")
}

model Bill {
  id           String        @id @default(cuid())
  name         String
  amount       Decimal       @db.Decimal(12, 2)
  currency     String        @default("AED")
  dueDay       Int           @default(1)
  isActive     Boolean       @default(true)
  reminderDays Int           @default(2)
  payments     BillPayment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("bills")
}

model BillPayment {
  id     String   @id @default(cuid())
  billId String
  bill   Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  amount Decimal  @db.Decimal(12, 2)
  note   String?
  paidAt DateTime @default(now())

  @@index([billId])
  @@map("bill_payments")
}

model MealPlan {
  id        String   @id @default(cuid())
  weekLabel String
  plan      Json
  createdAt DateTime @default(now())

  @@map("meal_plans")
}

model AiPrompt {
  id        String   @id @default(cuid())
  key       String   @unique
  content   String
  updatedAt DateTime @updatedAt

  @@map("ai_prompts")
}

model MoneyAdvice {
  id                   String   @id @default(cuid())
  summary              String
  emergencyFundNeeded  Float
  emergencyFundCurrent Float
  investableAmount     Float
  suggestions          Json
  createdAt            DateTime @default(now())

  @@map("money_advices")
}

model UserPreference {
  id            String   @id @default("default")
  entertainment String[]
  food          String[]
  likes         String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("user_preferences")
}

model WeekendPlan {
  id        String   @id @default(cuid())
  weekLabel String
  plan      Json
  createdAt DateTime @default(now())

  @@map("weekend_plans")
}

model AppSettings {
  id                     String   @id @default("default")
  currency               String   @default("AED")
  defaultPageSize        Int      @default(20)
  defaultAccountId       String?
  defaultTransactionType String   @default("expense")
  defaultDashboardPeriod String   @default("3m")
  autoCategorize         Boolean  @default(true)
  telegramEnabled        Boolean  @default(false)
  telegramBotToken       String?
  telegramWebhookSecret  String?
  telegramChatId         String?
  smsApiKey              String?
  aiEnabled              Boolean  @default(false)
  openaiApiKey           String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("app_settings")
}

model Currency {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  symbol    String
  rateToUsd Float    @default(1.0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("currencies")
}
