generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth Models ───────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?
  username       String?   @unique
  email          String    @unique
  hashedPassword String?
  image          String?
  emailVerified  DateTime?
  role                String    @default("user")
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts       OAuthAccount[]
  sessions       Session[]

  categories            Category[]
  bankAccounts          Account[]
  tags                  Tag[]
  persons               Person[]
  smsPatterns           SmsPattern[]
  merchantCategoryRules MerchantCategoryRule[]
  itemGroups            ItemGroup[]
  aiPrompts             AiPrompt[]
  notificationTemplates NotificationTemplate[]
  transactions          Transaction[]
  savingsGoals          SavingsGoal[]
  incomeSources         IncomeSource[]
  reserves              Reserve[]
  installments          Installment[]
  bills                 Bill[]
  mealPlans             MealPlan[]
  moneyAdvices          MoneyAdvice[]
  billNegotiations      BillNegotiation[]
  chatSessions          ChatSession[]
  wealthPlans           WealthPlan[]
  weekendPlans          WeekendPlan[]
  shoppingLists         ShoppingList[]
  householdMembers      HouseholdMember[]
  sentInvites           HouseholdInvite[]
  blogPosts             BlogPost[]
  challenges            Challenge[]
  badges                Badge[]
  trips                 Trip[]
  appSettings           AppSettings?
  userPreference        UserPreference?

  @@map("users")
}

model BlogPost {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String?
  content       String
  coverImage    String?
  status        String    @default("draft")
  tags          String[]
  readingTime   Int       @default(5)
  seoTitle      String?
  seoDescription String?
  publishedAt   DateTime?
  authorId      String
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([publishedAt])
  @@index([authorId])
  @@map("blog_posts")
}

model BlogAiMemory {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("blog_ai_memory")
}

model Household {
  id        String              @id @default(cuid())
  name      String
  members   HouseholdMember[]
  invites   HouseholdInvite[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@map("households")
}

model HouseholdMember {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("member")
  joinedAt    DateTime  @default(now())

  @@unique([householdId, userId])
  @@index([userId])
  @@map("household_members")
}

model HouseholdInvite {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  email       String
  token       String    @unique @default(cuid())
  status      String    @default("pending")
  invitedById String
  invitedBy   User      @relation(fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([token])
  @@index([householdId])
  @@map("household_invites")
}

model OAuthAccount {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("oauth_accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ─── App Models ────────────────────────────────────────────────

model Category {
  id            String                 @id @default(cuid())
  name          String
  color         String                 @default("#6b7280")
  icon          String?
  userId        String
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  transactions  Transaction[]
  budget        Budget?
  merchantRules MerchantCategoryRule[]
  splits        TransactionSplit[]     @relation("SplitCategories")

  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

model Budget {
  id              String   @id @default(cuid())
  categoryId      String   @unique
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  monthlyLimit    Decimal  @db.Decimal(12, 2)
  alertThreshold  Int      @default(80)
  rolloverEnabled Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("budgets")
}

model Tag {
  id           String           @id @default(cuid())
  name         String
  color        String           @default("#6b7280")
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  transactions TransactionTag[]

  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

model TransactionTag {
  transactionId String
  tagId         String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@map("transaction_tags")
}

model Account {
  id           String        @id @default(cuid())
  name         String
  type         String        @default("bank")
  bank         String?
  color        String        @default("#3b82f6")
  icon         String?
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId])
  @@map("accounts")
}

model Transaction {
  id           String               @id @default(cuid())
  date         DateTime
  time         String?
  amount       Decimal?             @db.Decimal(12, 2)
  currency     String               @default("AED")
  type         String
  categoryId   String?
  category     Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  accountId    String
  account      Account              @relation(fields: [accountId], references: [id])
  merchant     String?
  description  String?
  items        String?
  source       String?
  spreadMonths Int?
  confirmed    Boolean              @default(true)
  hasReceipt   Boolean              @default(false)
  mediaFiles   String[]
  mood         String?
  location     String?
  latitude     Float?
  longitude    Float?
  mergedIntoId String?
  mergedInto   Transaction?         @relation("MergedTransactions", fields: [mergedIntoId], references: [id])
  mergedFrom   Transaction[]        @relation("MergedTransactions")
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags               TransactionTag[]
  splits             TransactionSplit[]   @relation("TransactionSplits")
  lineItems          TransactionItem[]
  tripId             String?
  trip               Trip?                @relation(fields: [tripId], references: [id], onDelete: SetNull)
  installmentPayment InstallmentPayment?
  billPayment        BillPayment?
  incomeDeposit      IncomeDeposit?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([date])
  @@index([categoryId])
  @@index([accountId])
  @@index([type])
  @@index([merchant])
  @@index([mergedIntoId])
  @@index([userId])
  @@index([tripId])
  @@map("transactions")
}

model MerchantCategoryRule {
  id         String   @id @default(cuid())
  pattern    String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, pattern])
  @@index([userId])
  @@map("merchant_category_rules")
}

model SavingsGoal {
  id            String    @id @default(cuid())
  name          String
  description   String?
  targetAmount  Decimal   @db.Decimal(12, 2)
  currentAmount Decimal   @db.Decimal(12, 2) @default(0)
  currency      String    @default("AED")
  deadline      DateTime?
  color         String    @default("#10b981")
  status        String    @default("active")
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@map("savings_goals")
}

model Person {
  id          String             @id @default(cuid())
  name        String
  phone       String?
  color       String             @default("#6b7280")
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  splits      TransactionSplit[]
  settlements Settlement[]

  @@unique([userId, name])
  @@index([userId])
  @@map("persons")
}

model Settlement {
  id        String   @id @default(cuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime @default(now())
  note      String?
  source    String?
  createdAt DateTime @default(now())

  @@map("settlements")
}

model TransactionSplit {
  id            String       @id @default(cuid())
  transactionId String
  transaction   Transaction  @relation("TransactionSplits", fields: [transactionId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?    @relation("SplitCategories", fields: [categoryId], references: [id], onDelete: SetNull)
  personId      String?
  person        Person?      @relation(fields: [personId], references: [id], onDelete: SetNull)
  amount        Decimal      @db.Decimal(12, 2)
  description   String?
  createdAt     DateTime     @default(now())

  @@index([transactionId])
  @@index([personId])
  @@map("transaction_splits")
}

model TransactionItem {
  id             String      @id @default(cuid())
  transactionId  String
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  name           String
  normalizedName String      @default("")
  quantity       Float       @default(1)
  unitPrice      Float?
  totalPrice     Float
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())

  @@index([transactionId])
  @@index([normalizedName])
  @@map("transaction_items")
}

model ItemGroup {
  id            String   @id @default(cuid())
  canonicalName String
  rawNames      String[]
  source        String   @default("manual")
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, canonicalName])
  @@index([userId])
  @@map("item_groups")
}

model ShoppingList {
  id        String             @id @default(cuid())
  name      String
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ShoppingListItem[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([userId])
  @@map("shopping_lists")
}

model ShoppingListItem {
  id             String       @id @default(cuid())
  listId         String
  list           ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  itemName       String
  normalizedName String       @default("")
  quantity       Float        @default(1)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([listId])
  @@index([normalizedName])
  @@map("shopping_list_items")
}

model SmsPattern {
  id                   String   @id @default(cuid())
  name                 String
  regex                String
  type                 String   // "income" | "expense" | "auto"
  priority             Int      @default(50)
  amountCaptureGroup   Int      @default(1)
  merchantCaptureGroup Int?
  enabled              Boolean  @default(true)
  creditKeywords       String?  // comma-separated, for type="auto"
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([userId, name])
  @@index([priority])
  @@index([userId])
  @@map("sms_patterns")
}

model IncomeSource {
  id         String          @id @default(cuid())
  name       String
  amount     Decimal         @db.Decimal(12, 2)
  depositDay Int             @default(1)
  currency   String          @default("AED")
  isActive   Boolean         @default(true)
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  deposits   IncomeDeposit[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([userId])
  @@map("income_sources")
}

model IncomeDeposit {
  id             String        @id @default(cuid())
  incomeSourceId String
  incomeSource   IncomeSource  @relation(fields: [incomeSourceId], references: [id], onDelete: Cascade)
  amount         Decimal       @db.Decimal(12, 2)
  note           String?
  receivedAt     DateTime      @default(now())
  transactionId  String?       @unique
  transaction    Transaction?  @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([incomeSourceId])
  @@map("income_deposits")
}

model Reserve {
  id            String             @id @default(cuid())
  name          String
  amount        Decimal            @db.Decimal(12, 2)
  currency      String             @default("AED")
  type          String
  location      String
  note          String?
  ticker        String?
  quantity      Decimal?           @db.Decimal(12, 6)
  purchasePrice Decimal?           @db.Decimal(12, 2)
  userId        String
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots     ReserveSnapshot[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([userId])
  @@map("reserves")
}

model ReserveSnapshot {
  id         String   @id @default(cuid())
  reserveId  String
  reserve    Reserve  @relation(fields: [reserveId], references: [id], onDelete: Cascade)
  amount     Decimal  @db.Decimal(12, 2)
  note       String?
  recordedAt DateTime @default(now())

  @@index([reserveId])
  @@map("reserve_snapshots")
}

model Installment {
  id                  String               @id @default(cuid())
  name                String
  amount              Decimal              @db.Decimal(12, 2)
  currency            String               @default("AED")
  dueDay              Int                  @default(1)
  totalCount          Int?
  paidCount           Int                  @default(0)
  isActive            Boolean              @default(true)
  reminderDays        Int                  @default(2)
  paymentInstructions String?
  userId              String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments     InstallmentPayment[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([userId])
  @@map("installments")
}

model InstallmentPayment {
  id            String       @id @default(cuid())
  installmentId String
  installment   Installment  @relation(fields: [installmentId], references: [id], onDelete: Cascade)
  amount        Decimal      @db.Decimal(12, 2)
  note          String?
  paidAt        DateTime     @default(now())
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([installmentId])
  @@map("installment_payments")
}

model Bill {
  id                  String        @id @default(cuid())
  name                String
  amount              Decimal       @db.Decimal(12, 2)
  currency            String        @default("AED")
  dueDay              Int           @default(1)
  isActive            Boolean       @default(true)
  reminderDays        Int           @default(2)
  paymentInstructions String?
  userId              String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments     BillPayment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
  @@map("bills")
}

model BillPayment {
  id            String       @id @default(cuid())
  billId        String
  bill          Bill         @relation(fields: [billId], references: [id], onDelete: Cascade)
  amount        Decimal      @db.Decimal(12, 2)
  note          String?
  paidAt        DateTime     @default(now())
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([billId])
  @@map("bill_payments")
}

model MealPlan {
  id        String   @id @default(cuid())
  weekLabel String
  plan      Json
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("meal_plans")
}

model AiPrompt {
  id        String   @id @default(cuid())
  key       String
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
  @@map("ai_prompts")
}

model NotificationTemplate {
  id        String   @id @default(cuid())
  key       String
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
  @@map("notification_templates")
}

model MoneyAdvice {
  id                   String   @id @default(cuid())
  summary              String
  emergencyFundNeeded  Float
  emergencyFundCurrent Float
  investableAmount     Float
  suggestions          Json
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())

  @@index([userId])
  @@map("money_advices")
}

model WealthPlan {
  id                 String   @id @default(cuid())
  wealthScore        Int
  scoreBreakdown     Json
  monthlySurplus     Float
  investableCapital  Float
  projections        Json
  actions            Json
  summary            String
  completedActions   String[] @default([])
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())

  @@index([userId])
  @@map("wealth_plans")
}

model ChatSession {
  id        String   @id @default(cuid())
  title     String
  messages  Json
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("chat_sessions")
}

model BillNegotiation {
  id                  String   @id @default(cuid())
  totalMonthlySavings Float
  totalYearlySavings  Float
  recommendations     Json
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())

  @@index([userId])
  @@map("bill_negotiations")
}

model UserPreference {
  id            String   @id @default(cuid())
  entertainment String[]
  food          String[]
  likes         String[]
  city          String   @default("Dubai")
  companionType String   @default("solo")
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("user_preferences")
}

model WeekendPlan {
  id                   String   @id @default(cuid())
  weekLabel            String
  plan                 Json
  ratings              Json?
  linkedTransactionIds String[]
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())

  @@index([userId])
  @@map("weekend_plans")
}

model AppSettings {
  id                     String   @id @default(cuid())
  currency               String   @default("AED")
  defaultPageSize        Int      @default(20)
  defaultAccountId       String?
  defaultTransactionType String   @default("expense")
  defaultDashboardPeriod String   @default("3m")
  autoCategorize         Boolean  @default(true)
  telegramEnabled        Boolean  @default(false)
  telegramBotToken       String?
  telegramWebhookSecret  String?
  telegramChatId         String?
  smsApiKey              String?
  aiEnabled              Boolean  @default(false)
  openaiApiKey           String?
  notifyPaymentReminders Boolean  @default(true)
  notifyWeekendPlan      Boolean  @default(true)
  notifyMonthlyReport    Boolean  @default(true)
  notifyWebTransaction   Boolean  @default(true)
  notifySmsTransaction   Boolean  @default(true)
  developerApiKey        String?
  featureFlags           Json     @default("{}")
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("app_settings")
}

model Currency {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  symbol    String
  rateToUsd Float    @default(1.0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("currencies")
}

model Challenge {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // "no-spend-day", "no-spend-weekend", "save-target", "streak-logging", "under-budget"
  title       String
  description String
  targetValue Decimal? @db.Decimal(12, 2) // target amount for save-target
  startDate   DateTime
  endDate     DateTime
  status      String   @default("active") // "active", "completed", "failed"
  progress    Int      @default(0) // percentage 0-100
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("challenges")
}

model Badge {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // "first-transaction", "week-streak", "month-streak", "budget-master", "saver", "no-spend-hero"
  name        String
  description String
  icon        String   // emoji
  earnedAt    DateTime @default(now())

  @@unique([userId, type])
  @@index([userId])
  @@map("badges")
}

model Trip {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  currency     String
  startDate    DateTime
  endDate      DateTime?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  transactions Transaction[]

  @@index([userId])
  @@map("trips")
}
