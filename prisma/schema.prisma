generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id            String                 @id @default(cuid())
  name          String                 @unique
  color         String                 @default("#6b7280")
  icon          String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  transactions  Transaction[]
  budget        Budget?
  merchantRules MerchantCategoryRule[]
  splits        TransactionSplit[]     @relation("SplitCategories")

  @@map("categories")
}

model Budget {
  id             String   @id @default(cuid())
  categoryId     String   @unique
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  monthlyLimit   Decimal  @db.Decimal(12, 2)
  alertThreshold Int      @default(80)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("budgets")
}

model Tag {
  id           String           @id @default(cuid())
  name         String           @unique
  color        String           @default("#6b7280")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  transactions TransactionTag[]

  @@map("tags")
}

model TransactionTag {
  transactionId String
  tagId         String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@map("transaction_tags")
}

model Account {
  id           String        @id @default(cuid())
  name         String        @unique
  bank         String?
  color        String        @default("#3b82f6")
  icon         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]

  @@map("accounts")
}

model Transaction {
  id           String               @id @default(cuid())
  date         DateTime
  time         String?
  amount       Decimal?             @db.Decimal(12, 2)
  currency     String               @default("AED")
  type         String
  categoryId   String?
  category     Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  accountId    String
  account      Account              @relation(fields: [accountId], references: [id])
  merchant     String?
  description  String?
  items        String?
  source       String?
  hasReceipt   Boolean              @default(false)
  mediaFiles   String[]
  mergedIntoId String?
  mergedInto   Transaction?         @relation("MergedTransactions", fields: [mergedIntoId], references: [id])
  mergedFrom   Transaction[]        @relation("MergedTransactions")
  tags         TransactionTag[]
  splits       TransactionSplit[]   @relation("TransactionSplits")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([date])
  @@index([categoryId])
  @@index([accountId])
  @@index([type])
  @@index([merchant])
  @@index([mergedIntoId])
  @@map("transactions")
}

model MerchantCategoryRule {
  id         String   @id @default(cuid())
  pattern    String   @unique
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@map("merchant_category_rules")
}

model SavingsGoal {
  id            String    @id @default(cuid())
  name          String
  targetAmount  Decimal   @db.Decimal(12, 2)
  currentAmount Decimal   @db.Decimal(12, 2) @default(0)
  deadline      DateTime?
  color         String    @default("#10b981")
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("savings_goals")
}

model Person {
  id          String             @id @default(cuid())
  name        String             @unique
  phone       String?
  color       String             @default("#6b7280")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  splits      TransactionSplit[]
  settlements Settlement[]

  @@map("persons")
}

model Settlement {
  id        String   @id @default(cuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime @default(now())
  note      String?
  source    String?
  createdAt DateTime @default(now())

  @@map("settlements")
}

model TransactionSplit {
  id            String       @id @default(cuid())
  transactionId String
  transaction   Transaction  @relation("TransactionSplits", fields: [transactionId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?    @relation("SplitCategories", fields: [categoryId], references: [id], onDelete: SetNull)
  personId      String?
  person        Person?      @relation(fields: [personId], references: [id], onDelete: SetNull)
  amount        Decimal      @db.Decimal(12, 2)
  description   String?
  createdAt     DateTime     @default(now())

  @@index([transactionId])
  @@index([personId])
  @@map("transaction_splits")
}

model AppSettings {
  id                     String   @id @default("default")
  currency               String   @default("AED")
  defaultPageSize        Int      @default(20)
  defaultAccountId       String?
  defaultTransactionType String   @default("expense")
  defaultDashboardPeriod String   @default("3m")
  autoCategorize         Boolean  @default(true)
  telegramEnabled        Boolean  @default(false)
  telegramBotToken       String?
  telegramWebhookSecret  String?
  telegramChatId         String?
  smsApiKey              String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("app_settings")
}
